# Backend Environment Variables Example

# Secret key for JWT token signing
JWT_SECRET=your_jwt_secret_key_here

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/capstone

# Google OAuth Client ID (for public portal login)
GOOGLE_CLIENT_ID=your_google_client_id_here

# Postgres / PostGIS Configuration (Optional - for police stations database)
# Option A: Single connection string
# PG_URI=postgres://postgres:password@localhost:5432/capstone

# Option B: Discrete connection variables
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=capstone

# Server Port (Defaults to 5000)
PORT=5000
